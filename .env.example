# Web3Forms — odesílání kontaktního formuláře (https://web3forms.com).
# Formulář odesílá přímo prohlížeč Web3Forms, který e-mail přepošle na adresu
# navázanou na tento klíč. Klíč je veřejný (proto NEXT_PUBLIC_). Bez něj
# formulář zobrazí chybovou hlášku.
NEXT_PUBLIC_WEB3FORMS_KEY=68a79222-0f50-4ac7-95cf-9dc69bda3f7d

# Sanity CMS (volitelné) — fotky galerie a reference.
# Když NEJSOU vyplněné, web běží na statickém obsahu (fallback). Vše funguje jako dosud.
# (Pozn.: /studio route byla odstraněna kvůli statickému exportu — lze vrátit z gitu.)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Read token POUZE pro draft/preview čtení. Veřejné publikované čtení ho NEPOTŘEBUJE — nech prázdné.
SANITY_API_READ_TOKEN=
